{
  "name": "shieldkid",
  "version": "0.1.0",
  "private": true,
  "description": "Ferramenta open-source de verificação de idade e controle parental em conformidade com a Lei Felca (Lei 15.211/2025 — ECA Digital)",
  "license": "MIT",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest",
    "test:e2e": "playwright test",
    "sdk:build": "tsup src/sdk/index.ts --format esm,cjs,iife --global-name ShieldKid --minify --dts"
  },
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@tanstack/react-query": "^5.91.2",
    "@trpc/client": "^11.13.4",
    "@trpc/next": "^11.13.4",
    "@trpc/react-query": "^11.13.4",
    "@trpc/server": "^11.13.4",
    "better-auth": "^1.5.5",
    "drizzle-orm": "^0.45.1",
    "next": "^16.2.0",
    "pg": "^8.20.0",
    "pg-boss": "^12.14.0",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "superjson": "^2.2.6",
    "tsup": "^8.5.1",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.0.3",
    "eslint-config-next": "^16.2.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
