# Database
DATABASE_URL=postgresql://shieldkid:shieldkid@localhost:5432/shieldkid

# Security — generate with: openssl rand -hex 32
HMAC_SECRET=change-me-generate-with-openssl-rand-hex-32
ENCRYPTION_KEY=change-me-generate-with-openssl-rand-hex-32

# Auth (dashboard admin)
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:3000

# Age AI service (InsightFace) — runs via docker compose
AGE_AI_URL=http://localhost:8100

# Serpro CPF API (OPTIONAL — without it, only AI verification is available)
# Each platform contracts their own access at https://servicos.serpro.gov.br
# SERPRO_API_URL=https://gateway.apiserpro.serpro.gov.br
# SERPRO_CLIENT_ID=your-client-id
# SERPRO_CLIENT_SECRET=your-client-secret

# Dev mode: set to "true" to use mock Serpro responses (no real API calls)
SERPRO_MOCK=true

# Webhook (optional — receive events in your app)
# WEBHOOK_URL=https://your-app.com/webhooks/shieldkid
# WEBHOOK_SECRET=your-webhook-secret

# Email (optional — for parental control notifications)
# Option A: Resend
# RESEND_API_KEY=re_xxx
# Option B: SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
